{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/medicaltranslator",
      "destination": "/medicaltranslator.html"
    },
    {
      "source": "/medicaltranslator/",
      "destination": "/medicaltranslator.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
